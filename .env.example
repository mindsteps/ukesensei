# Supabase (free tier: https://supabase.com)
# Quick setup via CLI (links project, pushes schema, sets Vercel env):
#   yarn setup:cloud
# Grant admin after signing in once:
#   yarn admin:grant your@email.com
# Re-apply schema only:
#   yarn setup:db
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sign-in is anonymous — enable it under
# Supabase → Authentication → Providers → Anonymous Sign-Ins.

# Optional legacy backend (local dev)
VITE_API_URL=http://localhost:3001/api
